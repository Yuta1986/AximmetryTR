{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PDF: Install Markdown Dependency",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pip",
        "install",
        "--user",
        "markdown"
      ],
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--target",
        "pdf",
        "--output-dir",
        "exports"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown (with Inline TOC)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--target",
        "pdf",
        "--output-dir",
        "exports",
        "--toc-mode",
        "inline"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HTML: Export Active Markdown",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--target",
        "html",
        "--output-dir",
        "exports"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HTML: Export Active Markdown (with Sidebar TOC)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--target",
        "html",
        "--output-dir",
        "exports",
        "--toc-mode",
        "sidebar"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
