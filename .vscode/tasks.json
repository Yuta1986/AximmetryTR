{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PDF: Install Markdown Dependency",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pip",
        "install",
        "--user",
        "markdown"
      ],
      "problemMatcher": []
    },
    {
      "label": "Export: Sync Active Markdown (All Patterns)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_all_patterns.py",
        "${file}",
        "--output-dir",
        "build/exports"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--target",
        "pdf",
        "--output-dir",
        "build/exports"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown (with Inline TOC)",
      "type": "shell",
