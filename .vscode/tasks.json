{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PDF: Install Markdown Dependency",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pip",
        "install",
        "--user",
        "markdown"
      ],
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--output-dir",
        "exports"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "PDF: Export Active Markdown (with TOC)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/export_pdf.py",
        "${file}",
        "--output-dir",
        "exports",
        "--with-toc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
